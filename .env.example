# MarketBar backend env — copy to .env (never commit .env).
# All keys below are OPTIONAL for Phase 1 (notify-only). The engine runs
# without any of them; missing keys degrade gracefully, they never crash.

# CoinMarketCap fallback for crypto prices. If unset, the poller uses CoinGecko
# only and skips CMC (no crash). Get a free key at https://coinmarketcap.com/api/
CMC_API_KEY=

# Shared secret protecting GET /api/zones/evaluate (the Vercel cron trigger).
# If set, callers must send it as the `x-evaluate-token` header or `?token=`.
# Leave unset locally; set it in the Vercel project env for production.
EVALUATE_TOKEN=

# Log verbosity: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Override runtime-state file locations (Vercel FS is read-only outside /tmp).
# ZONES_PATH=/tmp/zones.json
# PUSH_TOKENS_PATH=/tmp/push-tokens.json

# ── PHASE 2 (Blofin read) / PHASE 3 (trade execution) — NOT USED YET ──
# BLOFIN_API_KEY=
# BLOFIN_API_SECRET=
# BLOFIN_API_PASSPHRASE=
